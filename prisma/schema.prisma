generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  nativeLang   String   @default("ru")
  createdAt    DateTime @default(now())

  progress UserProgress[]
  stats    UserStats?
}

model Lesson {
  id           Int    @id @default(autoincrement())
  number       Int    @unique
  titleKz      String
  titleRu      String
  grammarTopic String
  hoursEstimate Float @default(8)
  theoryKz     String @db.Text
  theoryRu     String @db.Text
  dialogueKz   String @db.Text
  dialogueRu   String @db.Text
  phrases      Json   @default("[]")

  exercises Exercise[]
  quiz      Quiz?
  progress  UserProgress[]
}

model Exercise {
  id       Int    @id @default(autoincrement())
  lessonId Int
  type     String // FILL_BLANK | MATCH | BUILD_SENTENCE
  prompt   String @db.Text
  options  Json   @default("[]")
  answer   String @db.Text

  lesson Lesson @relation(fields: [lessonId], references: [id])
}

model Quiz {
  id       Int    @id @default(autoincrement())
  lessonId Int    @unique

  lesson    Lesson     @relation(fields: [lessonId], references: [id])
  questions Question[]
}

model Question {
  id            Int    @id @default(autoincrement())
  quizId        Int
  textKz        String
  textRu        String
  options       Json
  correctAnswer String

  quiz Quiz @relation(fields: [quizId], references: [id])
}

model UserProgress {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  bestScore Int      @default(0)
  attempts  Int      @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

model UserStats {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  streak         Int      @default(0)
  lastActiveDate DateTime?
  totalHours     Float    @default(0)

  user User @relation(fields: [userId], references: [id])
}
